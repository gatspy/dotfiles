#!/usr/bin/env bash
#
# bootstrap - Dotfiles 一键部署脚本
#
# 用法: script/bootstrap

cd "$(dirname "$0")/.."
DOTFILES_ROOT=$(pwd -P)

set -e

echo ''
echo '╔════════════════════════════════════════════════════════════╗'
echo '║          Dotfiles Bootstrap - 一键部署                      ║'
echo '╚════════════════════════════════════════════════════════════╝'
echo ''

# 加载公共函数库
source "${DOTFILES_ROOT}/script/lib.sh" 2>/dev/null || {
  echo "错误: 无法加载 script/lib.sh"
  exit 1
}

# 初始化 Git 子模块
setup_submodules () {
  if [[ -f "$DOTFILES_ROOT/.gitmodules" ]]; then
    log_info '初始化 Git 子模块'

    if [[ -d "$DOTFILES_ROOT/tmux/.git" ]]; then
      log_success 'Git 子模块已初始化'
      return 0
    fi

    git submodule update --init --recursive

    if [[ $? -eq 0 ]]; then
      log_success 'Git 子模块初始化完成'
    else
      log_error 'Git 子模块初始化失败'
      exit 1
    fi
  fi
}

# 安装 dotfiles 符号链接
install_dotfiles () {
  log_info '安装 Dotfiles 符号链接'

  for src in $(find -H "$DOTFILES_ROOT" -maxdepth 2 -name '*.symlink' -not -path '*.git*' -not -path '*/config/*'); do
    filename=$(basename "$src" .symlink)
    dst="$HOME/.$filename"
    symlink_with_backup "$src" "$dst"
  done
}

# Helper function to install XDG config files
install_xdg_config() {
  local tool=$1
  local src_file=$2
  local dst_dir=$3
  local dst_file=$4

  if [[ -f "$DOTFILES_ROOT/$src_file" ]]; then
    ensure_dir "$dst_dir"
    symlink_with_backup "$DOTFILES_ROOT/$src_file" "$dst_dir/$dst_file"
  fi
}

# 安装外部工具配置
install_configs () {
  log_info '安装外部工具配置'

  # Mise 配置
  if [[ -f "$DOTFILES_ROOT/config/mise/config.toml.symlink" ]]; then
    ensure_dir ~/.config/mise
    symlink_with_backup "$DOTFILES_ROOT/config/mise/config.toml.symlink" ~/.config/mise/config.toml
  fi

  # Sheldon 配置
  if [[ -f "$DOTFILES_ROOT/config/sheldon/plugins.toml.symlink" ]]; then
    ensure_dir ~/.config/sheldon
    symlink_with_backup "$DOTFILES_ROOT/config/sheldon/plugins.toml.symlink" ~/.config/sheldon/plugins.toml
  fi

  # Starship 配置
  if [[ -f "$DOTFILES_ROOT/config/starship.toml.symlink" ]]; then
    ensure_dir ~/.config
    symlink_with_backup "$DOTFILES_ROOT/config/starship.toml.symlink" ~/.config/starship.toml
  fi

  # Tmux 配置
  if [[ -f "$DOTFILES_ROOT/tmux/.tmux.conf" ]]; then
    symlink_with_backup "$DOTFILES_ROOT/tmux/.tmux.conf" ~/.tmux.conf
  fi

  # Tmux 本地配置
  if [[ ! -f "$HOME/.tmux.conf.local" ]] && [[ -f "$DOTFILES_ROOT/tmux/.tmux.conf.local" ]]; then
    cp "$DOTFILES_ROOT/tmux/.tmux.conf.local" ~/.tmux.conf.local
    log_success "创建: ~/.tmux.conf.local"
  fi

  # Hammerspoon 配置
  if [[ -d "$DOTFILES_ROOT/hammerspoon" ]]; then
    symlink_with_backup "$DOTFILES_ROOT/hammerspoon" ~/.hammerspoon
  fi

  # Karabiner 配置（目录链接）
  if [[ -d "$DOTFILES_ROOT/karabiner" ]]; then
    symlink_with_backup "$DOTFILES_ROOT/karabiner" ~/.config/karabiner
  fi

  # Git 提交消息模板
  if [[ -f "$DOTFILES_ROOT/git/gitmessage.symlink" ]]; then
    symlink_with_backup "$DOTFILES_ROOT/git/gitmessage.symlink" ~/.gitmessage
  fi
}

# 检查 Git 配置
check_gitconfig () {
  log_info '检查 Git 配置'

  local gitconfig="$DOTFILES_ROOT/git/gitconfig.symlink"

  # 检查是否仍使用占位符
  if grep -q "AUTHORNAME\|AUTHOREMAIL" "$gitconfig" 2>/dev/null; then
    log_warning '检测到 Git 配置中使用占位符'
    echo ''
    echo '  请编辑 git/gitconfig.symlink，填写你的用户信息：'
    echo ''
    echo '    [user]'
    echo '            name = Your Name'
    echo '            email = your.email@example.com'
    echo ''
    echo '  编辑后运行: exec zsh'
    echo ''
    return 1
  fi

  log_success 'Git 配置正常'
  return 0
}

# 安装依赖 (macOS)
install_dependencies () {
  if ! is_macos; then
    return 0
  fi

  log_info '安装系统依赖'

  if [[ -f "$DOTFILES_ROOT/bin/dot" ]]; then
    if source "$DOTFILES_ROOT/bin/dot" > /tmp/dotfiles-dot 2>&1; then
      log_success '依赖安装完成'
    else
      log_warning '依赖安装出现问题，请检查日志: /tmp/dotfiles-dot'
    fi
  else
    log_warning '未找到 bin/dot 脚本，跳过依赖安装'
  fi
}

# 主流程
main () {
  setup_submodules
  install_dotfiles
  install_configs
  install_dependencies

  # 检查 Git 配置（非阻塞）
  check_gitconfig || true

  echo ''
  echo '╔════════════════════════════════════════════════════════════╗'
  echo '║                   ✅ 部署完成！                             ║'
  echo '╠════════════════════════════════════════════════════════════╣'
  echo '║  运行以下命令启动新 Shell:                                  ║'
  echo '║    exec zsh                                                ║'
  echo '║                                                            ║'
  echo '║  或重新加载配置:                                            ║'
  echo '║    source ~/.zshrc                                          ║'
  echo '╚════════════════════════════════════════════════════════════╝'
  echo ''
}

main "$@"
